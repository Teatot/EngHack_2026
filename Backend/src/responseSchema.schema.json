{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "recommendation": {
        "type": "string"
      },
      "links": {
        "type": "array",
        "items": {
          "type": "string",
          "format": "uri"
        }
      },
      "linkNum": {
        "type": "integer",
        "minimum": 0
      }
    },
    "required": ["recommendation", "links", "linkNum"],
    "additionalProperties": false
  }