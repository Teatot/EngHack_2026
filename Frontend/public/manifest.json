{
  "manifest_version": 3,
  "name": "Job Analyzer",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "description": "Chrome extension shell that hosts the React frontend for the full stack app.",
  "action": {
    "default_title": "Open App",
    "default_popup": "index.html"
  },
  "permissions": [
    "scripting",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "scrapeDOM.js"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}